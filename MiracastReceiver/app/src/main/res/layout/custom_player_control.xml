<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:background="#CC000000"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 标题和缓冲状态 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/exo_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- 缓冲状态指示器 -->
        <ProgressBar
            android:id="@+id/buffering_indicator"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:indeterminateTint="@color/accent"
            android:visibility="gone" />

        <!-- 画质选择器 -->
        <ImageButton
            android:id="@+id/btn_quality"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="画质"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_menu_preferences"
            android:tint="@color/text_primary" />
    </LinearLayout>

    <!-- 进度条和时间 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/exo_position"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <androidx.media3.ui.DefaultTimeBar
            android:id="@+id/exo_progress"
            android:layout_width="0dp"
            android:layout_height="26dp"
            android:layout_weight="1"
            app:played_color="@color/accent"
            app:buffered_color="@color/text_secondary"
            app:unplayed_color="#40FFFFFF"
            app:scrubber_color="@color/accent"
            app:scrubber_enabled_size="16dp"
            app:scrubber_disabled_size="0dp" />

        <TextView
            android:id="@+id/exo_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 控制按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- 上一个 -->
        <ImageButton
            android:id="@+id/exo_prev"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="上一个"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="@color/text_primary" />

        <!-- 后退 10 秒 -->
        <ImageButton
            android:id="@+id/exo_rew"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="后退 10 秒"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_media_rew"
            android:tint="@color/text_primary" />

        <!-- 播放/暂停 -->
        <ImageButton
            android:id="@+id/exo_play_pause"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_margin="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="播放/暂停"
            android:scaleType="fitCenter"
            android:tint="@color/text_primary" />

        <!-- 前进 10 秒 -->
        <ImageButton
            android:id="@+id/exo_ffwd"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="前进 10 秒"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_media_ff"
            android:tint="@color/text_primary" />

        <!-- 下一个 -->
        <ImageButton
            android:id="@+id/exo_next"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="下一个"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="@color/text_primary" />
    </LinearLayout>

    <!-- 底部功能栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- 播放速度 -->
        <TextView
            android:id="@+id/tv_playback_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:text="1.0x"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:padding="4dp"
            android:background="?attr/selectableItemBackground" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- 字幕按钮 -->
        <ImageButton
            android:id="@+id/btn_subtitle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="字幕"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_menu_info_details"
            android:tint="@color/text_primary" />

        <!-- 全屏按钮 -->
        <ImageButton
            android:id="@+id/btn_fullscreen"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_margin="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="全屏"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_menu_crop"
            android:tint="@color/text_primary" />
    </LinearLayout>

</LinearLayout>
